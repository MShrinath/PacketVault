# PacketVault - example environment variables
#
# Copy this file to `.env` for local testing (do NOT commit real secrets).
# In Netlify, set the same variables in the Site > Settings > Build & deploy > Environment
# or use the Netlify CLI (`netlify env:set KEY value`).

# GitHub repository used to store the shared note and uploaded files
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# GitHub personal access token with `repo` scope (keep this secret)
# Example placeholder — replace with a real token only in Netlify or a local .env
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (match values in your functions if you change defaults)
#UPLOADS_DIR=uploads
#NOTE_PATH=sharednote.txt

# Security: Never commit the real `GITHUB_TOKEN` to source control.